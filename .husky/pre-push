branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ]; then
  echo "ERROR: Direct pushes to main are not allowed. Use a pull request."
  exit 1
fi

commit_count=$(git rev-list --count main.."$branch")

if [ "$commit_count" -gt 1 ]; then
  echo "ERROR: Branch '$branch' has $commit_count commits (expected 1)."
  echo "Squash or amend before pushing. Run: git rebase -i main"
  exit 1
fi
